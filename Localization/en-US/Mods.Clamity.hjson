Items: {
	Mounts: {
		FlameCube: {
			DisplayName: Exo Box (Calamity Edition)
			Tooltip:
				'''
				Materializes a quite cozy and extremely nimble flying Calamitas-styled Exo throne
				Hold [KEY] while sitting in the throne to move slower for more precision
				'An angry gamer is a very dangerous gamer'
				'Side Note: He fire protective if you forgot'
				'''
		}

		PlagueStation: {
			DisplayName: Exo Box (Plague Edition)
			Tooltip:
				'''
				Materializes a quite cozy and extremely nimble flying Plague-styled Exo throne
				Hold [KEY] while sitting in the throne to move slower for more precision
				'A radical fan gamer is a virus gamer'
				'''
		}
	}

	BaseBook1: {
		DisplayName: Printer Paper
		ObtainmentHint: "[c/F79BC6:This book is sold by the common merchant]"
		Tooltip: Just an ordinary, blank piece paper
	}

	BaseBook2: {
		DisplayName: Common Brochure
		ObtainmentHint: "[c/F79BC6:This book is sold by someone with a curse]"
		Tooltip:
			'''
			Just an ordinary brochure, recommending you to travel to various places
			It is filled with ads, per usual
			'''
	}

	BaseBook3: {
		DisplayName: Basic Book
		ObtainmentHint: "[c/F79BC6:This book is sold by an archmage]"
		Tooltip: Just an ordinary book, nothing too interesting about it
	}

	BaseBook4: {
		DisplayName: Common Tome
		ObtainmentHint: "[c/F79BC6:This book is sold by a wizard who enjoys living in the Hallow]"
		Tooltip:
			'''
			It's written in a language you do understand
			However, this tome doesn't actually do anything...
			'''
	}

	HowToClamity: {
		DisplayName: How To Clamity
		ObtainmentHint: "[c/F79BC6:A clam taking refuge in the Azafure is in possession of this book]"
		Tooltip:
			'''
			An instruction book on how to make clamitous event
			As you read, you start feeling you mind sliping away...
			You closed the book before it was too late, but you can still hear clams clicking in your mind
			'''
	}
}

