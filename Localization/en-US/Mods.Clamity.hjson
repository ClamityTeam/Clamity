Configs: {
	ClamityConfig: {
		DisplayName: Clamity Config

		UsesEnchantedMetalInShadowspecBarRecipe: {
			Label: Enchanted Metal In Shadowspec Bar Recipe
			Tooltip: Toggles the addition of Enchanted Metal in the Shadowspec Bar recipe
		}

		ChangesCalamityRecipes: {
			Label: Calamity Recipe Adjustments
			Tooltip: Adjusts some of Calamities recipes to use materials from this mod
		}

		UsesClamityWeaponsInCalamityRecipes: {
			Label: Clamity Weapons In Calamity Recipes
			Tooltip: Adds weapon from this mod into some Calamity recipes
		}

		PermafrostSoldEnchantedMetal: {
			Label: Permafrost Sells Enchanted Metal
			Tooltip: Makes Permafrost sell Enchanted Metal ignoring existence of Frozen Hell
		}
